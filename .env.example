# Configuración de la Base de Datos (PostgreSQL)
POSTGRES_USER=tu_usuario_aqui
POSTGRES_PASSWORD=tu_contraseña_aqui
POSTGRES_DB=nombre_de_tu_base_de_datos_aqui
DB_HOST=nombre_del_host_de_tu_base_de_datos_aqui
DB_PORT=5432

# URL de conexión para SQLAlchemy
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${DB_HOST}:${DB_PORT}/${POSTGRES_DB}

# Configuración de la App
APP_PORT=8000
DEBUG=True

# MongoDB Configuration
MONGO_INITDB_ROOT_USERNAME=tu_usuario_aqui
MONGO_INITDB_ROOT_PASSWORD=tu_contraseña_aqui
MONGO_DB_NAME=nombre_de_tu_base_de_datos_aqui
MONGO_HOST=nombre_del_host_de_tu_base_de_datos_aqui
MONGO_PORT=27017

# La URL que usará FastAPI para conectarse
# Formato: mongodb://[usuario]:[password]@[host]:[puerto]/[base_de_datos]?authSource=admin
MONGO_URL=mongodb://${MONGO_INITDB_ROOT_USERNAME}:${MONGO_INITDB_ROOT_PASSWORD}@${MONGO_HOST}:${MONGO_PORT}/${MONGO_DB_NAME}?authSource=admin


# Configuración de entorno
ENV=dev

# MinIO / Object Storage Configuration
STORAGE_ROOT_USER=tu_usuario_aqui
STORAGE_ROOT_PASSWORD=tu_contraseña_aqui
STORAGE_PORT=tu_puerto_aqui #predeterminadamente 9000
STORAGE_HOST=http://nombre_del_host_de_tu_minio_aqui
STORAGE_BUCKET_NAME=nombre_de_tu_bucket_aqui
STORAGE_REGION=tu_region_aqui